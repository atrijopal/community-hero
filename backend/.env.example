# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_STORAGE_BUCKET=community-hero-fc07d.firebasestorage.app

# ─── Google Gemini ────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_key_here

# ─── Twilio WhatsApp ──────────────────────────────────────────────────────────
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Get Account SID + Auth Token from https://console.twilio.com
# 3. Join sandbox: WhatsApp message "join <sandbox-keyword>" to +14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Email (Gmail App Password) ───────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. myaccount.google.com → Security → App passwords
# 3. Create password for "Mail" — use the 16-char code, NOT your regular password
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PORT=8080
